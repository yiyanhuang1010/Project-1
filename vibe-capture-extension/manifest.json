{
  "manifest_version": 3,
  "name": "Likethis",
  "version": "1.5.0",
  "description": "Likethis — capture the page and generate a Vibe Coding prompt with Gemini or Claude",
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>", "https://api.anthropic.com/*", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Likethis"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
